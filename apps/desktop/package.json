{
  "name": "@hf-space/desktop",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rjwrakcjf-source/hf-space.git"
  },
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev-web\" \"wait-on http://localhost:5173 && electron .\"",
    "dev-web": "vite --config vite.config.js",
    "build": "pnpm build-web && electron-builder build --config electron-builder.config.js --publish never",
    "build-web": "vite build --config vite.config.js",
    "build:desktop": "pnpm build",
    "dist": "pnpm build-web && electron-builder build --config electron-builder.config.js --publish always",
    "lint": "eslint src --ext .js",
    "test": "jest"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "electron-store": "^8.2.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "@hf-space/api": "workspace:*",
    "@hf-space/core": "workspace:*",
    "@hf-space/models": "workspace:*",
    "@hf-space/security": "workspace:*"
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "vite": "^5.2.11",
    "@vitejs/plugin-react": "^4.3.0"
  }
}
