{
  "root": true,
  "env": {
    "node": true,
    "es2020": true,
    "jest": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["**/*.jsx"],
      "extends": ["eslint:recommended", "plugin:react/recommended"],
      "settings": { "react": { "version": "detect" } }
    }
  ]
}
