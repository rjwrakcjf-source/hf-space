# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=file:./runtime/sqlite/embedded.db

# JWT
JWT_SECRET=your-jwt-secret-here

# AI Providers (optional - use at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HF_TOKEN=
GROQ_API_KEY=

# Local AI (default URLs, change if needed)
OLLAMA_BASE_URL=http://localhost:11434
LOCALAI_BASE_URL=http://localhost:8080

# Security
ALLOWED_ORIGINS=http://localhost:5173
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# Upload
UPLOAD_DIR=/tmp/uploads

# Redis (optional)
REDIS_URL=

# Logging
LOG_LEVEL=info
