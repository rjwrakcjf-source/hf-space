# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output

# Cache
.turbo/
.cache/
*.cache
.eslintcache

# Electron build output
apps/desktop/dist/
apps/desktop/out/

# Model files (large binary)
*.gguf
*.ggml
*.bin
*.pt
*.safetensors
runtime/cache/models/*
!runtime/cache/models/.gitkeep

# SQLite database
*.db
*.sqlite
!runtime/sqlite/.gitkeep

# Temporary files
tmp/
temp/
runtime/temp/*
!runtime/temp/.gitkeep

# Security - never commit these
security/signing-keys/*.pem
!security/signing-keys/public.pem
security/audit-logs/*
!security/audit-logs/.gitkeep

# pnpm
.pnpm-store/
